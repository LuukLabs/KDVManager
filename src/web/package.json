  "scripts": {
    "api:generate": "orval --clean",
    "start": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "knip": "knip",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "translations:extract": "i18next -c ./i18next-parser.config.ts",
    "typecheck": "tsc -b && tsc -p tsconfig.test.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "reset": "orval --clean && eslint --fix ./src/api && prettier --write .",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:ci": "vitest run --reporter=dot --reporter=github-actions --coverage"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@babel/core": "^8.0.1",
    "@emotion/babel-plugin": "^11.13.5",
    "@eslint/js": "^10.0.1",
