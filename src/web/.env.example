# Build-time environment variables for the web app (Vite).
# Local development defaults live in the committed .env file; in container
# builds these are injected as build args (see src/docker-compose.yml and
# src/web/Dockerfile).

# API gateway base URL (Envoy). May be protocol-relative.
VITE_API_BASE_URL=//localhost:5200

# Auth0
VITE_APP_AUTH0_DOMAIN=kdvmanager-development.eu.auth0.com
VITE_APP_AUTH0_CLIENT_ID=4pgRAIUb8feIsPVo53UwqMMzgN0jFFFq
# Optional; defaults to https://api.kdvmanager.nl/
#VITE_APP_AUTH0_AUDIENCE=https://api.kdvmanager.nl/

# Browser telemetry (OpenTelemetry). Traces, error reports and web vitals are
# posted to <endpoint>/v1/traces. Leave unset to disable telemetry entirely.
# The /telemetry/ prefix on the API gateway proxies to the OTel collector.
#VITE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:5200/telemetry

# Release identifier reported as service.version (defaults to "unknown").
#VITE_APP_VERSION=local
